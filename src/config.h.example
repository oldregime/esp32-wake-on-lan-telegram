// ============================================================
// ESP32 Wake-on-LAN Telegram Bot — Configuration Template
// ============================================================
// SETUP INSTRUCTIONS:
//   1. Copy this file:  cp src/config.h.example src/config.h
//   2. Fill in all values below
//   3. config.h is listed in .gitignore — your secrets stay local
// ============================================================

#ifndef CONFIG_H
#define CONFIG_H

// ─────────────────────────────────────────
// TELEGRAM CONFIGURATION
// ─────────────────────────────────────────

// Get your bot token from @BotFather on Telegram
// Example: "1234567890:ABCDEFabcdef1234567890ABCDEFabcdef12"
#define BOT_TOKEN    "YOUR_BOT_TOKEN_HERE"

// Your Telegram numeric user ID — get it from @userinfobot
// Only this ID is authorised to control the ESP32
// Example: "987654321"
#define ALLOWED_ID   "YOUR_TELEGRAM_USER_ID_HERE"

// ─────────────────────────────────────────
// WIFI CONFIGURATION
// ─────────────────────────────────────────

// NOTE: ESP32 only supports 2.4 GHz WiFi — do NOT use a 5 GHz SSID
const char* WIFI_SSID     = "YOUR_WIFI_SSID";
const char* WIFI_PASSWORD = "YOUR_WIFI_PASSWORD";

// ─────────────────────────────────────────
// TIMEZONE & NTP
// ─────────────────────────────────────────

// UTC offset in seconds:
//   IST (India)  = UTC+5:30 = 19800
//   GMT (UK)     = UTC+0    = 0
//   EST (US)     = UTC-5    = -18000
//   PST (US)     = UTC-8    = -28800
//   CET (Europe) = UTC+1    = 3600
#define GMT_OFFSET_SEC      19800
#define DAYLIGHT_OFFSET_SEC 0

// NTP server — change if pool.ntp.org is unreachable in your region
#define NTP_SERVER "pool.ntp.org"

// ─────────────────────────────────────────
// SCHEDULED TASKS
// ─────────────────────────────────────────

// Daily Attendance Report — pings all devices and sends summary
// Default: 10:30 AM (window: 10:30–10:35 to avoid double-trigger)
#define ATTENDANCE_HOUR         10
#define ATTENDANCE_MINUTE       30
#define ATTENDANCE_END_MINUTE   35

// TrueNAS Backup Check — checks if NAS is online before backup window
// Auto-wakes the NAS via WoL if it is offline
// Default: 8:30 PM
#define TRUENAS_CHECK_HOUR        20
#define TRUENAS_CHECK_MINUTE      30
#define TRUENAS_CHECK_END_MINUTE  35

// ─────────────────────────────────────────
// TRUENAS DEVICE & REST API
// ─────────────────────────────────────────

// The name string must exactly match one entry in the devices[] array
// in main.cpp — case sensitive
#define TRUENAS_DEVICE_NAME "TrueNAS"

// TrueNAS IP Address or Hostname (do NOT include http:// or https://)
#define TRUENAS_IP          "192.168.29.179"

// Protocol for API calls (true = HTTPS, false = HTTP).
// Note: TrueNAS usually redirects HTTP to HTTPS on port 443.
#define TRUENAS_USE_HTTPS   true

// Choose ONE authorization method below:
// METHOD 1: API Key (Recommended)
// Create in TrueNAS Web UI -> Gear Icon -> API Keys.
#define TRUENAS_API_KEY     "YOUR_TRUENAS_API_KEY_HERE"

// METHOD 2: Basic Auth (Fallback if TRUENAS_API_KEY is commented out)
// To use Username/Password, COMMENT OUT the TRUENAS_API_KEY definition above.
// #define TRUENAS_USERNAME    "admin"
// #define TRUENAS_PASSWORD    "YOUR_TRUENAS_PASSWORD"


// ─────────────────────────────────────────
// DEVICE LIMITS & NETWORK
// ─────────────────────────────────────────

#define MAX_DEVICES  20         // Maximum devices in the managed list
#define WOL_PORT     9          // Standard Wake-on-LAN UDP port (do not change)
#define PING_TIMEOUT 2000       // TCP connect timeout in ms for status checks

// ─────────────────────────────────────────
// DEVICE CONFIG STRUCT
// ─────────────────────────────────────────

// Device structure — matches entries in main.cpp devices[] array
// Fields:
//   name      : friendly name used in Telegram commands (no spaces)
//   mac       : MAC address as uppercase colon-separated string
//   ip        : static or reserved DHCP IP address
//   wakeCount : runtime counter — initialise to 0
struct DeviceConfig {
    const char* name;
    const char* mac;
    const char* ip;
    int         wakeCount;
};

// ─────────────────────────────────────────
// EXAMPLE DEVICE ARRAY (add to main.cpp)
// ─────────────────────────────────────────
//
// DeviceConfig devices[MAX_DEVICES] = {
//     {"GamingPC",    "AA:BB:CC:DD:EE:FF", "192.168.1.101", 0},
//     {"Workstation", "11:22:33:44:55:66", "192.168.1.102", 0},
//     {"TrueNAS",     "DC:C2:C9:5A:76:2E", "192.168.1.103", 0},
// };
// int deviceCount = 3;
//
// Run scan_network.py to discover MAC addresses automatically.

#endif // CONFIG_H
